{
  "version": 2,
  "redirects": [
    { "source": "/", "destination": "/landing.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/public-config", "destination": "/api/public-config.js" },
    { "source": "/api/validate-email", "destination": "/api/validate-email.js" },
    { "source": "/api/submit", "destination": "/api/submit.js" },
    { "source": "/assets", "destination": "/assets.html" },
    { "source": "/assets/", "destination": "/assets.html" },
    { "source": "/estimate", "destination": "/index.html" },
    { "source": "/estimate/", "destination": "/index.html" }
  ]
}
