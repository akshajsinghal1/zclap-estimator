# --- Required now ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin auth (choose one approach) ---
# Option A (single user)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Option B (multi-user JSON)
# Example: [{"email":"manas@zclap.com","password":"..."}]
ADMIN_USERS_JSON=

# Recommended for secure cookie signing
ADMIN_SESSION_SECRET=

# --- CAPTCHA (Cloudflare Turnstile) ---
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Optional aliases supported in code
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional: set true to require CAPTCHA even on localhost
CAPTCHA_ENFORCE_LOCALHOST=

# --- Planned (AWS SES, not active yet) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
SES_FROM_NAME=
